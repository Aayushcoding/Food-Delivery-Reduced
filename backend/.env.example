# Copy this file to .env and fill in your values
# cp .env.example .env

# Port the backend server listens on
PORT=5000

# MongoDB connection string
# For local MongoDB:  mongodb://127.0.0.1:27017/food-delivery
# For MongoDB Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/food-delivery
MONGO_URI=mongodb://127.0.0.1:27017/food-delivery
